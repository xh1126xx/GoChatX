# GoChatX Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# MySQL connection string (required for authsvc)
DB_DSN=root:changeme@tcp(127.0.0.1:3306)/gochatx?parseTime=true

# JWT signing secret — must be at least 32 characters (required for authsvc)
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-chars

# Redis address (optional, defaults to 127.0.0.1:6379)
REDIS_ADDR=127.0.0.1:6379

# gRPC listen address (optional, defaults to :50051)
LISTEN_ADDR=:50051

# Docker Compose passwords
MYSQL_ROOT_PASSWORD=changeme
REDIS_PASSWORD=changeme
